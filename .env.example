# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=apple_plus

# JWT — secrets MUST be at least 32 characters in production
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail (Nodemailer)
# Development: use Mailtrap (https://mailtrap.io) — free, catches all outgoing emails
# Production:  use Gmail SMTP, Resend, SendGrid, or any SMTP relay
# Leave MAIL_HOST empty to disable email sending (logs will be printed instead)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@apple-plus.com

# MinIO / Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=apple-plus

# Swagger (set to true to enable in production)
SWAGGER_ENABLED=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
